# Base URL of the backend API. Must match a CORS_ORIGINS entry in the
# backend's .env (this frontend's own origin, e.g. http://localhost:5173).
VITE_API_BASE_URL=http://localhost:8000

# Shown in the app header / browser title. Purely cosmetic.
VITE_APP_NAME=JDK Manufacturing Operations

# Optional: override the dev server port (defaults to 5173).
# VITE_PORT=5173
