# Copy this file to .env and fill in real values before running the backend.

# --- Shared MySQL database (perennia-auth / perennia-access / perennia-search
#     / perennia-notify / perennia-files / JDK's own tables all live here) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jdk

# --- perennia-auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SIGNING_SECRET=
REQUIRE_EMAIL_VERIFICATION=true

# --- perennia-files ---
FILES_SIGNING_SECRET=
FILES_STORAGE_PATH=./var/files
FILES_MAX_UPLOAD_SIZE=52428800

# --- Application ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
